{
  "ReverseProxy": {
    
    "Routes": {
      "offender-route": {
        "ClusterId": "offender-cluster",
        "Match": {
          "Path": "/api/reverseProxyOffenders/{id}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/offender/{id}"
          }
        ]
      }
    },
    "Clusters": {
      "offender-cluster": {
        
        "Destinations": {
          "backend-api": {
            "Address": "https://localhost:7107"
          }
        }
      }

    }

  },


  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
