{
  "ReverseProxy": {

    "Routes": {
      "fee-route": {
        "ClusterId": "enterprise-one-cluster",
        "AuthorizationPolicy": "AdminOnly",
        "CorsPolicy": "FrontendPolicy",
        "Match": { "Path": "/api/reverseProxyFees/{id}" },
        "Transforms": [ { "PathPattern": "/api/fees/offender/{id}" } ]
      },
      "case-route": {
        "ClusterId": "offender-cluster",
        "AuthorizationPolicy": "AuthenticatedUser",
        "CorsPolicy": "FrontendPolicy",
        "Match": {
          "Path": "/api/reverseProxyCases/{id}"
        },
        "Transforms": [
          { "PathPattern": "/api/Case/offender/{id}" }
        ]
      },
      "offender-id-route": {
        "ClusterId": "offender-cluster",
        "AuthorizationPolicy": "AuthenticatedUser",
        "CorsPolicy": "FrontendPolicy",
        "Match": {
          "Path": "/api/reverseProxyOffenders/{id}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/offender/{id}"
          }
        ]
      },
      "offender-search-route": {
        "ClusterId": "offender-cluster",
        "AuthorizationPolicy": "AuthenticatedUser",
        "CorsPolicy": "FrontendPolicy",
        "Match": {
          "Path": "/api/reverseProxyOffenders"
        },
        "Transforms": [
          {
            "PathPattern": "/api/offender"
          }
        ]
      }
    },
    "Clusters": {
      "offender-cluster": {
        "Destinations": {
          "backend-api": {
            "Address": "https://localhost:7107"
          }
        }
      },
      "enterprise-one-cluster": {
        "Destinations": { "legacy-api": { "Address": "https://localhost:7295" } }
      }

    }

  },


  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
