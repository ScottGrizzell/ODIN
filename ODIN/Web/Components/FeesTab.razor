@inject Offenders Client

<div class="mt-3">
    <div class="d-flex justify-content-between">
        <h4>Financial Profile <small class="text-muted">(Source: Enterprise One)</small></h4>
        <button class="btn btn-danger btn-sm">Send Delinquent to Collections</button>
    </div>

    @if (fees == null)
    {
        <p>Loading fees...</p>
    }
    else
    {
        <table class="table table-hover mt-3">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Total</th>
                    <th>Balance</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fee in fees)
                {
                    <tr>
                        <td>@fee.FeeType</td>
                        <td>@fee.Amount.ToString("C")</td>
                        <td class="@(fee.Balance > 0 ? "text-danger" : "")">@fee.Balance.ToString("C")</td>
                        <td>@fee.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public int OffenderId { get; set; }
    private List<FeeDto>? fees;

    protected override async Task OnParametersSetAsync()
    {
        fees = await Client.GetFees(OffenderId);
    }
}