@inject Offenders Client

<div class="mt-3">
    <h4>Case History <small class="text-muted">(Source: Doc400)</small></h4>

    @if (isLoading)
    {
        <div class="d-flex align-items-center">
            <strong>Loading cases...</strong>
            <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
        </div>
    }
    else if (cases == null || !cases.Any())
    {
        <div class="alert alert-info">
            No active or historical cases found for this offender in Doc400.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Case #</th>
                        <th>Description</th>
                        <th>Filed Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in cases)
                    {
                        <tr>
                            <td><strong>@c.CaseNumber</strong></td>
                            <td>@c.CaseDescription</td>
                            <td>@c.FiledDate.ToShortDateString()</td>
                            <td>
                                <span class="badge @(c.Status == "Open" ? "bg-warning" : "bg-secondary")">
                                    @c.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    [Parameter] public int OffenderId { get; set; }
    private List<CaseDto>? cases;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        try
        {
            cases = await Client.GetOffenderCases(OffenderId);
        }
        finally
        {
            isLoading = false;
        }
    }
}